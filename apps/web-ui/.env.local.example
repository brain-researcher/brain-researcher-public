# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-32-character-random-string-here

# Public API base (UI + NextAuth will call the gateway which proxies /auth/* and /api/*)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Server-side fetch target for SSR (keep aligned with gateway)
INTERNAL_API_URL=http://localhost:8080

# Legacy variable (used in some places) — keep in sync with NEXT_PUBLIC_API_URL
NEXT_PUBLIC_BR_ORCH_URL=http://localhost:8080

# Google OAuth
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Azure AD OAuth
# Get from: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
# Use "organizations" for work/school accounts only, or "common" for all accounts
AZURE_AD_TENANT_ID=organizations

# GitHub OAuth
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Magic Link Email Service (using Resend as example)
# Get from: https://resend.com/api-keys
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=your-resend-api-key
EMAIL_FROM=noreply@brain-researcher.ai

# Optional: Domain allowlist for Microsoft (comma-separated)
# Uncomment to restrict to specific institutional domains
# ALLOWED_DOMAINS=stanford.edu,mit.edu,harvard.edu

# Backend API URL
BACKEND_URL=http://localhost:3001

# Cookie dev mode toggle for refresh tokens (matches backend BR_DEV_MODE)
BR_DEV_MODE=false
