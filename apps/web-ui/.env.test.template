# Real pipeline execution E2E (opt-in)
#
# Copy to `.env.test` and `source .env.test` before running:
#   npm run e2e:real
#
# Required:
BR_TEST_TOKEN=
BR_WEB_URL=http://localhost:3000

# Optional: choose what to run (must be compatible with your backend + data).
BR_TEST_DATASET_ID=ds:openneuro:ds000001
BR_TEST_TEMPLATE_ID=connectivity/nilearn_connectivity

# Optional JSON with extra parameters merged into the run plan.
# Example:
# BR_TEST_PARAMS_JSON={"participant_label":["sub-01","sub-02"],"atlas":"schaefer-200"}
BR_TEST_PARAMS_JSON=

# Optional: max wait time (milliseconds) for the run to complete.
# If < 1000, treated as minutes.
BR_TEST_MAX_RUN_MS=1800000

