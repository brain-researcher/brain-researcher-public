{
  "name": "brain-researcher",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "sync:monaco": "node scripts/sync-monaco-assets.mjs",
    "predev": "npm run sync:monaco && node scripts/repair-next-dev-cache.mjs",
    "dev": "next dev",
    "dev:3002": "PORT=3002 next dev",
    "prebuild": "npm run sync:monaco",
    "build": "next build",
    "start": "next start",
    "export": "next export",
    "deploy:ssr": "bash deploy-ssr.sh",
    "build:cloudflare": "npm run build && npx @cloudflare/next-on-pages",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "next lint",
    "lint:ci": "next lint --dir src/app --dir src/components/chat --dir src/lib --max-warnings=0",
    "test": "vitest --run",
    "test:watch": "vitest",
    "e2e": "node scripts/run-playwright.mjs test tests/e2e/chat.e2e.spec.ts --reporter=line",
    "e2e:routes": "node scripts/run-playwright.mjs test tests/e2e/routes.spec.ts --reporter=line",
    "e2e:prd": "node scripts/run-playwright.mjs test tests/e2e/prd.auth-routing.spec.ts tests/e2e/prd.keyflows.spec.ts tests/e2e/prd.tier1.core.spec.ts tests/e2e/prd.tier2.entry.spec.ts tests/e2e/prd.tier3.polish.spec.ts tests/e2e/prd.planned.workflow-execution.spec.ts --workers=1 --reporter=line",
    "e2e:real": "node scripts/run-playwright.mjs test --config=playwright.config.real-pipeline.ts --reporter=line",
    "e2e:headed": "node scripts/run-playwright.mjs test tests/e2e/chat.e2e.spec.ts --headed --reporter=line",
    "e2e:install": "playwright install chromium --with-deps",
    "test:e2e": "npm run e2e:install && npm run e2e",
    "postinstall": "npm run sync:monaco"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@next/bundle-analyzer": "^15.5.2",
    "@niivue/niivue": "^0.62.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
