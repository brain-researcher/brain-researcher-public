    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "js-yaml": "^4.1.1",
    "jspdf": "^3.0.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "monaco-editor": "^0.55.1",
    "next": "^14.2.0",
    "next-auth": "^4.24.13",
    "next-intl": "^4.3.5",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "react": "^18.3.1",
    "react-beautiful-dnd": "^13.1.1",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.5.2",
    "react-hook-form": "^7.68.0",
    "react-markdown": "^9.0.1",
