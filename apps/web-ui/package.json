    "@tanstack/react-query": "^5.0.0",
    "@types/d3": "^7.4.3",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-grid-layout": "^1.3.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "cmdk": "^0.2.0",
    "cytoscape": "^3.33.1",
    "cytoscape-cose-bilkent": "^4.1.0",
    "cytoscape-dagre": "^2.5.0",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "file-saver": "^2.0.5",
