# Brain Researcher Web UI Configuration
# Copy this file to .env.local and adjust the values as needed

# ==============================================================================
# BROWSER ROUTING MODE
# ==============================================================================
# Keep browser traffic same-origin through the Web UI unless you intentionally
# want direct public service URLs.
NEXT_PUBLIC_USE_API_PROXY=true

# ==============================================================================
# DIRECT PUBLIC URLS (Advanced / Opt-Out)
# ==============================================================================
# Provide these only if NEXT_PUBLIC_USE_API_PROXY=false
# NEXT_PUBLIC_API_URL=http://localhost:3001
# NEXT_PUBLIC_AGENT_API=http://localhost:8000
# NEXT_PUBLIC_BR_KG_API=http://localhost:5000
# NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

NEXT_PUBLIC_NICLIP_API=http://localhost:8001

# ==============================================================================
# SERVICE PORTS (Option 2: Port-based Configuration)
# ==============================================================================
# Alternatively, specify just ports and let the system construct internal URLs
# for the Next.js proxy layer.
ORCHESTRATOR_PORT=3001
AGENT_PORT=8000
BR_KG_PORT=5000
NICLIP_PORT=8001
WEB_UI_PORT=3000

# ==============================================================================
# SERVICE HOSTS
# ==============================================================================
# Customize hosts for each service (defaults to localhost)
# Useful for Docker deployments or remote services
ORCHESTRATOR_HOST=localhost
AGENT_HOST=localhost
BR_KG_HOST=localhost
NICLIP_HOST=localhost
WEB_UI_HOST=localhost

# ==============================================================================
# PROTOCOLS
# ==============================================================================
# HTTP protocol (http or https)
HTTP_PROTOCOL=http

# WebSocket protocol (ws or wss)
WS_PROTOCOL=ws

# ==============================================================================
# OPTIONAL: Override specific endpoints
# ==============================================================================
# WebSocket base. In proxy mode the browser defaults to /ws.
# Only set NEXT_PUBLIC_WS_URL for a custom public websocket endpoint.
# NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# ==============================================================================
# SERVER-TO-SERVER INTERNAL BASE URLS (Preferred for Next API routes)
# ==============================================================================
# Use these for server-side proxy routes and avoid relying on NEXT_PUBLIC_*.
# BR_AGENT_URL=http://localhost:8000
# BR_ORCHESTRATOR_URL=http://localhost:3001
# BR_KG_URL=http://localhost:5000

# ==============================================================================
# PIPELINE BUILDER & KG INTEGRATION
# ==============================================================================
# Enable debug mode for plan generation (shows selection reasons and candidates)
# This affects the /api/plan endpoint and pipeline builder UI
# NEXT_PUBLIC_PLAN_DEBUG_SELECTION=true

# Note: The following API routes are available for pipeline integration:
# - /api/kg/pipelines - List all pipeline templates from knowledge graph
# - /api/kg/tools - Fetch tools by intent/pipeline with KG hints
# - /api/plan - Generate execution plans (proxies to Agent planner)
# - /api/kg/search - Search operations and synonyms in knowledge graph

# ==============================================================================
# AUTHENTICATION (Optional)
# ==============================================================================
# Supabase Configuration
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# API Secret Key
# API_SECRET_KEY=your_api_secret_key

# ==============================================================================
# ANALYTICS (Optional)
# ==============================================================================
# NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ==============================================================================
# EXAMPLE CONFIGURATIONS
# ==============================================================================

# --- Local Development (default) ---
# ORCHESTRATOR_PORT=3001
# AGENT_PORT=8000
# BR_KG_PORT=5000

# --- Docker Compose ---
# ORCHESTRATOR_HOST=orchestrator
# AGENT_HOST=agent
# BR_KG_HOST=br-kg
# ORCHESTRATOR_PORT=3001
# AGENT_PORT=8000
# BR_KG_PORT=5000

# --- Production with HTTPS ---
# HTTP_PROTOCOL=https
# WS_PROTOCOL=wss
# NEXT_PUBLIC_USE_API_PROXY=true
# BR_AGENT_URL=https://agent.brainresearcher.ai
# BR_ORCHESTRATOR_URL=https://orchestrator.brainresearcher.ai
# BR_KG_URL=https://kg.brainresearcher.ai

# --- Custom Port Configuration ---
# Change ports if default ones are occupied
# ORCHESTRATOR_PORT=3004
# WEB_UI_PORT=3002
