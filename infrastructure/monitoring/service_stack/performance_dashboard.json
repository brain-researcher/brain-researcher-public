{
  "dashboard": {
    "id": null,
    "title": "Brain Researcher - Performance Metrics",
    "tags": ["brain-researcher", "performance"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Agent Query Processing Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "agent:query_processing_rate_5m",
            "legendFormat": "Queries/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Tool Execution Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "agent:tool_execution_rate_5m",
            "legendFormat": "{{tool_name}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "LLM Token Usage Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "agent:llm_token_usage_rate_5m",
            "legendFormat": "Tokens/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Graph Execution Time P95",
        "type": "timeseries",
        "targets": [
          {
            "expr": "agent:graph_execution_time_p95_5m",
            "legendFormat": "P95 Execution Time"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 5,
        "title": "BR-KG Query Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "br-kg:query_rate_5m",
            "legendFormat": "Knowledge Graph Queries/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 6,
        "title": "Semantic Search Latency P95",
        "type": "timeseries",
        "targets": [
          {
            "expr": "br-kg:semantic_search_latency_p95_5m",
            "legendFormat": "P95 Semantic Search Latency"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 7,
        "title": "Database Connection Pool Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "br-kg:database_connection_pool_usage",
            "legendFormat": "Pool Usage %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 90}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}
      },
      {
        "id": 8,
        "title": "HTTP Request Duration by Service",
        "type": "heatmap",
        "targets": [
          {
            "expr": "rate(http_request_duration_seconds_bucket[5m])",
            "legendFormat": "{{job}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
}