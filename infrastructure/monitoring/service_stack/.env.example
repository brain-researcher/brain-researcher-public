# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=secure_password_here

# Email/SMTP Configuration
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=alerts@brain-researcher.io
SMTP_PASSWORD=smtp_app_password_here

# Slack Integration
SLACK_API_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# PagerDuty Integration
PAGERDUTY_SERVICE_KEY=your_pagerduty_service_key_here

# Redis Configuration (if password protected)
REDIS_PASSWORD=redis_password_here

# Domain Configuration
MONITORING_DOMAIN=brain-researcher.local

# Retention Policies
PROMETHEUS_RETENTION_DAYS=30
LOKI_RETENTION_DAYS=30

# Resource Limits
PROMETHEUS_MEMORY_LIMIT=2g
GRAFANA_MEMORY_LIMIT=512m
LOKI_MEMORY_LIMIT=1g