    "oneOf": [
      {
        "properties": {
          "autoresearch_dir": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "pattern": "^\\s*$",
                "type": "string"
              }
            ]
          },
          "run_id": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "pattern": "^\\s*$",
                "type": "string"
              }
            ]
          }
        }
      },
      {
        "properties": {
          "autoresearch_dir": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "pattern": "^\\s*$",
                "type": "string"
              }
            ]
          },
          "run_id": {
            "minLength": 1,
            "pattern": "\\S",
            "type": "string"
          }
        },
        "required": [
          "run_id"
        ]
      },
      {
        "properties": {
          "autoresearch_dir": {
            "minLength": 1,
            "pattern": "\\S",
            "type": "string"
          },
          "run_id": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "pattern": "^\\s*$",
                "type": "string"
              }
            ]
          }
        },
        "required": [
          "autoresearch_dir"
        ]
      }
    ],
    "title": "scientific_report_generateArguments",
    "type": "object"
  },
  "output_schema": {
    "additionalProperties": true,
    "title": "scientific_report_generateDictOutput",
    "type": "object"
  },
  "examples": [
    {
      "input": {
        "run_id": "br_example_run",
        "analysis_sections": {
          "Results Summary": "Summarize key reviewed outputs here."
        },
        "compile_pdf": true,
        "revision_instructions": [
          "Restore figure captions and experiment-log provenance."
        ],
        "revision_source_artifacts": [
          {
            "label": "curated_tex",
            "role": "prior_report_source",
            "path": "/path/to/curated_report.tex"
          }
        ],
        "local_workspace": "/path/to/user/workspace",
        "local_workspace_manifest": {
          "source_files": [
            "README.md",
            "results/summary.json"
          ],
          "figures": [
            "figures/main_result.png"
          ],
          "scripts": [
            "scripts/reproduce.py"
          ],
          "logs": [
            "logs/run.log"
          ],
          "citations": [
            "references.bib"
          ],
          "required_revision": [
            "Read local workspace files before editing TeX.",
            "Add local figure paths, script paths, and provenance."
          ],
          "compile_command": "latexmk -pdf report.tex"
        }
      },
      "output": {
        "ok": true,
        "report_run_id": "br_report_run",
        "artifacts": {
          "markdown": "artifacts/report/draft_report.md",
          "tex": "artifacts/report/report.tex",
          "pdf": "artifacts/report/report.pdf",
          "handoff": "artifacts/report/report_revision_handoff.json"
        },
        "_agent_directive": {
          "report_revision_handoff": {
            "protocol": "br.report_revision_handoff.directive.v1",
            "purpose": "source_preserving_scientific_report_revision",
            "local_workspace_context": {
              "access_mode": "client_local_workspace",
              "path": "/path/to/user/workspace",
              "server_readable": false
            },
            "revision_instructions": [
              "Restore figure captions and experiment-log provenance."
            ]
          }
        }
      },
      "tested": false
    },
    {
      "input": {
        "analysis_sections": {
          "Results Summary": "Draft a plain report without scientific review."
        },
        "compile_pdf": true
      },
      "output": {
        "ok": true,
        "report_run_id": "br_report_run",
        "artifacts": {
          "markdown": "artifacts/report/draft_report.md",
          "tex": "artifacts/report/report.tex",
          "handoff": "artifacts/report/report_revision_handoff.json"
        }
      },
      "tested": false
    }
  ],
  "stability": "stable",
  "contract_version": "2026-05-27"
}
