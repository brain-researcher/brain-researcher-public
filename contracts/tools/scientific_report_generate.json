{
  "name": "scientific_report_generate",
  "tier": "ops",
  "surface_tier": "ops",
  "capability_family": "scientific_report",
  "description": "Draft a scientific report by reviewing one run/workspace and rendering LaTeX.\n\n    When ``run_id`` or ``autoresearch_dir`` is supplied, the tool delegates\n    review to the existing scientific-review MCP functions, converts the\n    resulting verdict into conservative report sections, merges optional\n    plain-text analysis sections, then calls ``latex_report_render``. When no\n    source is supplied, it degrades to a plain ``latex_report_render`` call over\n    the provided analysis sections and skips scientific review.\n\n    On successful render, the tool also writes a Markdown draft and a\n    ``report_revision_handoff`` manifest next to the generated TeX/style/template/PDF artifacts.\n    The handoff is a source-preserving contract for a coding agent: retrieve the\n    Markdown, TeX, LaTeX style/template assets, PDF, metadata, and handoff manifest; revise the TeX without\n    deleting or summarizing BR-generated content; add requested scientific\n    details, citations, figures, script paths, and provenance; then compile and\n    validate the revised PDF. Optional ``revision_instructions``,\n    ``revision_source_artifacts``, ``local_workspace``, and\n    ``local_workspace_manifest`` are persisted into that handoff so callers can\n    explicitly name details, local files, or prior report sources the coding agent\n    must restore. ``local_workspace`` is a coding-agent handoff pointer only; the\n    deployed MCP server does not assume it can read that filesystem path.",
  "input_schema": {
    "properties": {
      "run_id": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Run Id"
      },
      "autoresearch_dir": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Autoresearch Dir"
      },
      "workflow_id": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Workflow Id"
      },
      "logs_dir": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Logs Dir"
      },
      "task_id": {
        "default": "liu_component_v1",
        "title": "Task Id",
        "type": "string"
      },
      "title": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Title"
      },
      "authors": {
        "default": "Brain Researcher",
        "title": "Authors",
        "type": "string"
      },
      "analysis_sections": {
        "anyOf": [
          {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Analysis Sections"
      },
      "subtitle": {
        "default": "",
        "title": "Subtitle",
        "type": "string"
      },
      "institution": {
        "default": "",
        "title": "Institution",
        "type": "string"
      },
      "date": {
        "default": "",
        "title": "Date",
        "type": "string"
      },
      "use_judgment_critic": {
        "default": true,
        "title": "Use Judgment Critic",
        "type": "boolean"
      },
      "force_recompute": {
        "default": false,
        "title": "Force Recompute",
        "type": "boolean"
      },
      "compile_pdf": {
        "default": false,
        "title": "Compile Pdf",
        "type": "boolean"
      },
      "halt_on_review_block": {
        "default": false,
        "title": "Halt On Review Block",
        "type": "boolean"
      },
      "revision_instructions": {
        "anyOf": [
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Revision Instructions"
      },
      "revision_source_artifacts": {
        "anyOf": [
          {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Revision Source Artifacts"
      },
      "local_workspace": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
