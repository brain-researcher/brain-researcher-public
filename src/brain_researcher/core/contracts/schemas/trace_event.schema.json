{
  "$defs": {
    "IdsV1": {
      "description": "Stable identifiers for correlating objects/events across services.",
      "properties": {
        "analysis_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Analysis identifier if applicable",
          "title": "Analysis Id"
        },
        "job_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Job identifier",
          "title": "Job Id"
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Inbound API/UI request identifier",
          "title": "Request Id"
        },
        "run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Run identifier",
          "title": "Run Id"
        },
        "schema_version": {
          "const": "ids-v1",
          "default": "ids-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "session_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Conversation/session/thread id",
          "title": "Session Id"
        },
        "trace_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Distributed trace id",
          "title": "Trace Id"
        },
        "user_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "End-user id",
          "title": "User Id"
        },
        "workspace_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Workspace/project id",
          "title": "Workspace Id"
        }
      },
      "title": "IdsV1",
      "type": "object"
    },
    "PolicyRefV1": {
      "description": "Reference to the policy that governed a run/event.",
      "properties": {
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Human-readable notes",
          "title": "Notes"
        },
        "policy_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Checksum in the form sha256:<hex> when available",
          "title": "Policy Hash"
        },
        "policy_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Policy identifier",
          "title": "Policy Id"
        },
        "policy_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Where the policy came from (file/env/url)",
          "title": "Policy Source"
        },
        "schema_version": {
          "const": "policy-ref-v1",
          "default": "policy-ref-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "thresholds": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional thresholds used by the policy",
          "title": "Thresholds"
        }
      },
      "title": "PolicyRefV1",
      "type": "object"
    },
    "VersionRefV1": {
      "description": "Best-effort versions for reproducibility/auditing.",
      "properties": {
        "brain_researcher_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Installed brain_researcher package version",
          "title": "Brain Researcher Version"
        },
        "contracts_version": {
          "default": "contracts-v1",
          "description": "Version identifier for this contract set",
          "title": "Contracts Version",
          "type": "string"
        },
        "git_commit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Git commit SHA if known",
          "title": "Git Commit"
        },
        "image_digests": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Container/image digests",
          "title": "Image Digests",
          "type": "object"
        },
        "schema_version": {
          "const": "version-ref-v1",
          "default": "version-ref-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "tool_versions": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Tool/library versions",
          "title": "Tool Versions",
          "type": "object"
        }
      },
      "title": "VersionRefV1",
      "type": "object"
    }
  },
  "properties": {
    "event_id": {
      "title": "Event Id",
      "type": "string"
    },
    "event_type": {
      "title": "Event Type",
      "type": "string"
    },
    "ids": {
      "$ref": "#/$defs/IdsV1"
    },
    "payload": {
      "additionalProperties": true,
      "title": "Payload",
      "type": "object"
    },
    "policy": {
      "$ref": "#/$defs/PolicyRefV1"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "trace-event-v1",
      "default": "trace-event-v1",
      "title": "Schema Version",
      "type": "string"
    },
    "timestamp": {
      "title": "Timestamp",
      "type": "string"
    },
    "versions": {
      "$ref": "#/$defs/VersionRefV1"
    }
  },
  "required": [
    "run_id",
    "event_type",
    "timestamp"
  ],
  "title": "TraceEventV1",
  "type": "object"
}
