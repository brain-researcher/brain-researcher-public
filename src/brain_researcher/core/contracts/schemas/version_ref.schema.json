    },
    "schema_version": {
      "const": "version-ref-v1",
      "default": "version-ref-v1",
      "title": "Schema Version",
      "type": "string"
    },
    "tool_versions": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Tool/library versions",
      "title": "Tool Versions",
      "type": "object"
