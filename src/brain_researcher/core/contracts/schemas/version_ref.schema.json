      "type": "string"
    },
    "git_commit": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Git commit SHA if known",
      "title": "Git Commit"
    },
    "image_digests": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Container/image digests",
