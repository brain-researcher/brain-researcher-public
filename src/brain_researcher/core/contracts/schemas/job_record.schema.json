{
  "$defs": {
    "ArtifactKindV1": {
      "enum": [
        "file",
        "json",
        "blob",
        "bundle",
        "log",
        "trace"
      ],
      "title": "ArtifactKindV1",
      "type": "string"
    },
    "ArtifactV1": {
      "properties": {
        "artifact_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional stable artifact identifier",
          "title": "Artifact Id"
        },
        "bytes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Size in bytes when known",
          "title": "Bytes"
        },
        "created_at": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Unix timestamp (seconds) when recorded",
          "title": "Created At"
        },
        "ids": {
          "$ref": "#/$defs/IdsV1"
        },
        "job_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Owning job/analysis identifier",
          "title": "Job Id"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKindV1",
          "description": "High-level artifact kind"
        },
        "media_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "IANA media type (e.g. application/json, text/plain)",
          "title": "Media Type"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "policy": {
          "$ref": "#/$defs/PolicyRefV1"
        },
        "schema_version": {
          "const": "artifact-v1",
          "default": "artifact-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Checksum in the form sha256:<hex> when available",
          "title": "Sha256"
        },
        "tags": {
          "description": "Semantic tags/roles",
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "uri": {
          "description": "Relative path within the run directory, or an abstract URI",
          "title": "Uri",
          "type": "string"
        },
        "versions": {
          "$ref": "#/$defs/VersionRefV1"
        }
      },
      "required": [
        "kind",
        "uri"
      ],
      "title": "ArtifactV1",
      "type": "object"
    },
    "IdsV1": {
      "description": "Stable identifiers for correlating objects/events across services.",
      "properties": {
        "analysis_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Analysis identifier if applicable",
          "title": "Analysis Id"
        },
        "job_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Job identifier",
          "title": "Job Id"
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Inbound API/UI request identifier",
          "title": "Request Id"
        },
        "run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Run identifier",
          "title": "Run Id"
        },
        "schema_version": {
          "const": "ids-v1",
          "default": "ids-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "session_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Conversation/session/thread id",
          "title": "Session Id"
        },
        "trace_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Distributed trace id",
          "title": "Trace Id"
        },
        "user_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "End-user id",
          "title": "User Id"
        },
        "workspace_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Workspace/project id",
          "title": "Workspace Id"
        }
      },
      "title": "IdsV1",
      "type": "object"
    },
    "JobSpecV1": {
      "description": "Stable job request/specification (v1).",
      "properties": {
        "ids": {
          "$ref": "#/$defs/IdsV1"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "parameters": {
          "additionalProperties": true,
          "title": "Parameters",
          "type": "object"
        },
        "pipeline": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Requested pipeline/kind",
          "title": "Pipeline"
        },
        "policy": {
          "$ref": "#/$defs/PolicyRefV1"
        },
        "prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "User prompt / request",
          "title": "Prompt"
        },
        "schema_version": {
          "const": "job-spec-v1",
          "default": "job-spec-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "versions": {
          "$ref": "#/$defs/VersionRefV1"
        }
      },
      "title": "JobSpecV1",
      "type": "object"
    },
    "JobStatusV1": {
      "enum": [
        "pending",
        "queued",
        "claimed",
        "running",
        "succeeded",
        "failed",
        "cancelled",
        "cancelling",
        "timeout",
        "skipped",
        "paused",
        "retrying"
      ],
      "title": "JobStatusV1",
      "type": "string"
    },
    "PolicyRefV1": {
      "description": "Reference to the policy that governed a run/event.",
      "properties": {
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Human-readable notes",
          "title": "Notes"
        },
        "policy_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Checksum in the form sha256:<hex> when available",
          "title": "Policy Hash"
        },
        "policy_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Policy identifier",
          "title": "Policy Id"
        },
        "policy_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Where the policy came from (file/env/url)",
          "title": "Policy Source"
        },
        "schema_version": {
          "const": "policy-ref-v1",
          "default": "policy-ref-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "thresholds": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional thresholds used by the policy",
          "title": "Thresholds"
        }
      },
      "title": "PolicyRefV1",
      "type": "object"
    },
    "VersionRefV1": {
      "description": "Best-effort versions for reproducibility/auditing.",
      "properties": {
        "brain_researcher_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Installed brain_researcher package version",
          "title": "Brain Researcher Version"
        },
        "contracts_version": {
          "default": "contracts-v1",
          "description": "Version identifier for this contract set",
          "title": "Contracts Version",
          "type": "string"
        },
        "git_commit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Git commit SHA if known",
          "title": "Git Commit"
        },
        "image_digests": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Container/image digests",
          "title": "Image Digests",
          "type": "object"
        },
        "schema_version": {
          "const": "version-ref-v1",
          "default": "version-ref-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "tool_versions": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Tool/library versions",
          "title": "Tool Versions",
          "type": "object"
        }
      },
      "title": "VersionRefV1",
      "type": "object"
    }
  },
  "description": "Durable job record / API-facing job resource (v1).",
  "properties": {
    "artifacts": {
      "items": {
        "$ref": "#/$defs/ArtifactV1"
      },
      "title": "Artifacts",
      "type": "array"
    },
    "attempt": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": 0,
      "description": "Current attempt number (0-based)",
      "title": "Attempt"
    },
    "backend": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Execution backend (local/slurm/...)",
      "title": "Backend"
    },
    "cancel_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cancel Reason"
    },
    "cancellation_requested": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": false,
      "title": "Cancellation Requested"
    },
    "claimed_at": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Claimed At"
    },
    "cpus": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": 1,
      "title": "Cpus"
    },
    "created_at": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "title": "Created At"
    },
    "error_message": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error Message"
    },
    "exit_code": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Exit Code"
    },
    "finished_at": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Finished At"
    },
    "gpu_req": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": 0,
      "description": "GPU slots requested",
      "title": "Gpu Req"
    },
    "gpu_type": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Gpu Type"
    },
    "ids": {
      "$ref": "#/$defs/IdsV1"
    },
    "job_id": {
      "description": "Job identifier (canonical; analysis_id is an alias)",
      "title": "Job Id",
      "type": "string"
    },
    "job_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Job Name"
    },
    "kind": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Job kind/pipeline",
      "title": "Kind"
    },
    "last_heartbeat": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Heartbeat"
    },
    "lease_expires_at": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Lease Expires At"
    },
    "max_attempts": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": 3,
      "description": "Maximum attempts",
      "title": "Max Attempts"
    },
    "memory_gb": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": 4.0,
      "title": "Memory Gb"
    },
    "payload_json": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": "{}",
      "description": "Legacy opaque job payload (JSON string)",
      "title": "Payload Json"
    },
    "policy": {
      "$ref": "#/$defs/PolicyRefV1"
    },
    "priority": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": 0,
      "description": "Scheduling priority (higher = sooner)",
      "title": "Priority"
    },
    "project_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Project Id"
    },
    "provenance_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Provenance reference (prefer a store-relative path when exposed)",
      "title": "Provenance Path"
    },
    "queued_at": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Queued At"
    },
    "run_after": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Delayed execution timestamp (epoch seconds)",
      "title": "Run After"
    },
    "run_dir": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Run directory reference (prefer a store-relative path when exposed)",
      "title": "Run Dir"
    },
    "run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Run Id"
    },
    "schema_version": {
      "const": "job-record-v1",
      "default": "job-record-v1",
      "title": "Schema Version",
      "type": "string"
    },
    "session_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Session Id"
    },
    "skip_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Skip Reason"
    },
    "spec": {
      "anyOf": [
        {
          "$ref": "#/$defs/JobSpecV1"
        },
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Spec"
    },
    "started_at": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started At"
    },
    "status": {
      "$ref": "#/$defs/JobStatusV1",
      "description": "Current job status"
    },
    "user_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "User Id"
    },
    "versions": {
      "$ref": "#/$defs/VersionRefV1"
    },
    "walltime_minutes": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": 60,
      "title": "Walltime Minutes"
    },
    "worker_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Worker Id"
    }
  },
  "required": [
    "job_id",
    "status"
  ],
  "title": "JobRecordV1",
  "type": "object"
}
