# Backend OAuth Configuration

# JWT Secret (generate a secure random string)
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# Dev-mode toggle for refresh cookie attributes
# true  -> secure=False, SameSite=Lax (HTTP localhost dev)
# false -> secure=True,  SameSite=Strict (production HTTPS)
BR_DEV_MODE=false

# Google OAuth (same as frontend)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Azure AD OAuth (same as frontend)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
# Use "organizations" for work/school accounts only
AZURE_AD_TENANT_ID=organizations

# GitHub OAuth (same as frontend)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Redis for Magic Link storage (optional, uses in-memory if not set)
REDIS_URL=redis://localhost:6379/0

# Email configuration for Magic Links
EMAIL_FROM=noreply@brain-researcher.ai
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=your-resend-api-key

# Frontend URL for redirects
FRONTEND_URL=http://localhost:3000

# OAuth redirect base URL
OAUTH_REDIRECT_BASE_URL=http://localhost:3001

# Optional: Domain allowlist for Microsoft (comma-separated)
# ALLOWED_DOMAINS=stanford.edu,mit.edu,harvard.edu

# Existing services (keep these)
AGENT_SERVICE_URL=http://localhost:8000
BR_KG_SERVICE_URL=http://localhost:5000
NICLIP_SERVICE_URL=http://localhost:8001

# Telemetry and Monitoring (optional)
ENABLE_TELEMETRY=false
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Prometheus metrics (default: enabled)
BR_METRICS_ENABLED=true

# CORS configuration for web UI deployments (comma-separated origins)
# ORCHESTRATOR_ALLOWED_ORIGINS=https://brain-researcher.pages.dev,https://brain-researcher-api.com
