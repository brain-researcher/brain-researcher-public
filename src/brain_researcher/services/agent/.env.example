# Brain Researcher Agent Environment Configuration

# BR-KG API Configuration
BR_KG_API_URL=http://localhost:5010

# LLM Configuration
## DeepSeek (default)
# API base is OpenAI-compatible; prefer setting BASE explicitly for new endpoints
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
# If DeepSeek changes endpoints, set BASE to the root (e.g., https://api.deepseek.com)
DEEPSEEK_API_BASE=https://api.deepseek.com
# Explicit DeepSeek model (overrides default)
DEEPSEEK_MODEL=deepseek-chat

# Default model selection
DEFAULT_LLM_MODEL=deepseek-chat

# Alternative LLM Providers:
# For Anthropic Claude:
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# DEFAULT_LLM_MODEL=claude-3-sonnet-20240229

# For OpenAI:
# OPENAI_API_KEY=your_openai_api_key_here
# DEFAULT_LLM_MODEL=gpt-4o

# For Google Gemini (optional — requires extra packages):
# GOOGLE_API_KEY=your_gemini_api_key_here
# DEFAULT_LLM_MODEL=gemini-1.5-pro  # or gemini-1.5-flash for speed

# Tool Configuration
TOOL_TIMEOUT_SECONDS=300  # 5 minutes default timeout for tool execution

# Agent Configuration
USE_TOOL_RETRIEVER=false  # Set to true to enable LLM-based tool selection
MAX_ITERATIONS=10  # Maximum number of agent iterations

# Logging
LOG_LEVEL=INFO
