"""
Integration tests for Package-based neuroimaging capabilities.

Tests the capability-based interfaces with package management backend support.
"""

import pytest
import tempfile
from pathlib import Path
import numpy as np
import nibabel as nib

from brain_researcher.tools.capabilities import (
    SkullStripCapability,
    RegistrationCapability,
    SegmentationCapability,
    BiasCorrectionCapability
)
from brain_researcher.core.package_resolver import PackageResolver as PackageResolver


@pytest.fixture
def sample_nifti():
    """Create a sample NIfTI file for testing."""
    with tempfile.NamedTemporaryFile(suffix=".nii.gz", delete=False) as f:
        # Create simple 3D image
        data = np.random.randn(64, 64, 32)
        # Add some structure (sphere in center)
        center = np.array([32, 32, 16])
        for i in range(64):
            for j in range(64):
                for k in range(32):
                    dist = np.linalg.norm([i, j, k] - center)
                    if dist < 15:
                        data[i, j, k] += 2.0
        
        img = nib.Nifti1Image(data, np.eye(4))
        nib.save(img, f.name)
        yield Path(f.name)
        
        # Cleanup
        Path(f.name).unlink(missing_ok=True)


@pytest.fixture
def output_dir():
    """Create a temporary output directory."""
    with tempfile.TemporaryDirectory() as tmpdir:
        yield Path(tmpdir)


class TestPackageResolver:
    """Test CVMFS resolver functionality."""
    
    def test_package_detection(self):
        """Test CVMFS detection."""
        resolver = PackageResolver()
        
        # Check if CVMFS is available (may not be in CI)
        if Path("/cvmfs/neurodesk.ardc.edu.au").exists():
            assert resolver._cvmfs_available
            
            # Test finding a common tool
            fsl_backends = resolver.find_tool("fsl")
            assert len(fsl_backends) > 0, "Should find at least one FSL backend"
    
    def test_backend_priority(self):
        """Test backend selection priority."""
        resolver = PackageResolver()
        
        # Find any tool
        tools = resolver.list_available_tools()
        if tools:
            # Get first available tool
            tool_name = list(tools.keys())[0]
            backends = tools[tool_name]
            
            # Check backends are sorted by priority
            priorities = [b.priority for b in backends]
            assert priorities == sorted(priorities), "Backends should be sorted by priority"


class TestSkullStripCapability:
    """Test skull stripping capability."""
    
    def test_initialization(self):
        """Test capability initialization."""
        cap = SkullStripCapability()
        
        # Should have at least one backend (nilearn fallback)
        backends = cap.get_available_backends()
        assert len(backends) > 0, "Should have at least one backend available"
    
    def test_skull_strip_with_fallback(self, sample_nifti, output_dir):
        """Test skull stripping with Python fallback."""
        cap = SkullStripCapability()
        
        output_file = output_dir / "brain.nii.gz"
        
        # Force nilearn backend (always available)
        success = cap.run(
            input_file=str(sample_nifti),
            output_file=str(output_file),
            prefer_backend="nilearn"
        )
        
        # Check if nilearn is available
        if "nilearn" in cap.backends:
            assert success, "Skull stripping should succeed with nilearn"
            assert output_file.exists(), "Output file should be created"
            
            # Verify output is valid NIfTI
            img = nib.load(str(output_file))
            assert img.shape == nib.load(str(sample_nifti)).shape


class TestRegistrationCapability:
    """Test registration capability."""
    
    def test_initialization(self):
        """Test capability initialization."""
        cap = RegistrationCapability()
        
        # Should have at least one backend
        backends = cap.get_available_backends()
        assert len(backends) > 0, "Should have at least one backend available"
    
    def test_linear_registration_with_fallback(self, sample_nifti, output_dir):
        """Test linear registration with Python fallback."""
        cap = RegistrationCapability()
        
        # Use same image as moving and fixed for simple test
        output_file = output_dir / "registered.nii.gz"
        
        # Force nilearn backend (always available)
        success = cap.run_linear(
            moving=str(sample_nifti),
            fixed=str(sample_nifti),
            output=str(output_file),
            prefer_backend="nilearn"
        )
        
        # Check if nilearn is available
        if "nilearn" in cap.backends:
            assert success, "Registration should succeed with nilearn"
            assert output_file.exists(), "Output file should be created"
    
    def test_backend_capabilities(self):
        """Test backend capability reporting."""
        cap = RegistrationCapability()
        backends = cap.get_available_backends()
        
        for name, info in backends.items():
            assert "capabilities" in info
            
            # Check capability consistency
            if name == "nilearn":
                assert "linear" in info["capabilities"]
                assert "nonlinear" not in info["capabilities"]
            elif name in ["fsl", "ants"]:
                if name in backends:  # Only if actually available
                    assert "linear" in info["capabilities"]
                    assert "nonlinear" in info["capabilities"]


class TestSegmentationCapability:
    """Test segmentation capability."""
    
    def test_initialization(self):
        """Test capability initialization."""
        cap = SegmentationCapability()
        
        # Should have at least one backend
        backends = cap.get_available_backends()
        assert len(backends) > 0, "Should have at least one backend available"
    
    def test_segmentation_with_fallback(self, sample_nifti, output_dir):
        """Test segmentation with Python fallback."""
        cap = SegmentationCapability()
        
        output_prefix = str(output_dir / "seg")
        
        # Force sklearn backend (if available)
        outputs = cap.run(
            input_file=str(sample_nifti),
            output_prefix=output_prefix,
            n_classes=3,
            prefer_backend="sklearn",
            brain_extracted=True
        )
        
        # Check if sklearn is available
        if "sklearn" in cap.backends:
            assert outputs, "Segmentation should produce outputs"
            assert "segmentation" in outputs, "Should have segmentation output"
            
            # Verify segmentation file exists
            seg_file = Path(outputs["segmentation"])
            if seg_file.exists():
                # Verify it's a valid NIfTI
                img = nib.load(str(seg_file))
                assert img.shape == nib.load(str(sample_nifti)).shape


class TestBiasCorrectionCapability:
    """Test bias field correction capability."""
    
    def test_initialization(self):
        """Test capability initialization."""
        cap = BiasCorrectionCapability()
        
        # Should have at least one backend
        backends = cap.get_available_backends()
        assert len(backends) > 0, "Should have at least one backend available"
    
    def test_bias_correction_with_fallback(self, sample_nifti, output_dir):
        """Test bias correction with Python fallback."""
        cap = BiasCorrectionCapability()
        
        output_file = output_dir / "corrected.nii.gz"
        
        # Force SimpleITK backend (if available)
        success = cap.run(
            input_file=str(sample_nifti),
            output_file=str(output_file),
            prefer_backend="simpleitk"
        )
        
        # Check if SimpleITK is available
        if "simpleitk" in cap.backends:
            assert success, "Bias correction should succeed with SimpleITK"
            assert output_file.exists(), "Output file should be created"
            
            # Verify output is valid NIfTI
            img = nib.load(str(output_file))
            assert img.shape == nib.load(str(sample_nifti)).shape
    
    def test_bias_field_estimation(self, sample_nifti, output_dir):
        """Test bias field estimation from images."""
        cap = BiasCorrectionCapability()
        
        bias_field_file = output_dir / "bias_field.nii.gz"
        
        # Estimate bias field (original vs original should give uniform field)
        success = cap.estimate_bias_field(
            input_file=str(sample_nifti),
            corrected_file=str(sample_nifti),
            output_bias_field=str(bias_field_file)
        )
        
        assert success, "Bias field estimation should succeed"
        assert bias_field_file.exists(), "Bias field file should be created"


class TestCapabilityIntegration:
    """Test integration between capabilities."""
    
    def test_pipeline_skull_strip_then_segment(self, sample_nifti, output_dir):
        """Test pipeline: skull strip -> segmentation."""
        # Initialize capabilities
        skull_strip = SkullStripCapability()
        segmentation = SegmentationCapability()
        
        # Step 1: Skull strip
        brain_file = output_dir / "brain.nii.gz"
        if "nilearn" in skull_strip.backends:
            success = skull_strip.run(
                input_file=str(sample_nifti),
                output_file=str(brain_file),
                prefer_backend="nilearn"
            )
            
            if success and brain_file.exists():
                # Step 2: Segment brain-extracted image
                seg_prefix = str(output_dir / "seg")
                
                if "sklearn" in segmentation.backends:
                    outputs = segmentation.run(
                        input_file=str(brain_file),
                        output_prefix=seg_prefix,
                        n_classes=3,
                        brain_extracted=True,
                        prefer_backend="sklearn"
                    )
                    
                    assert outputs, "Pipeline should complete successfully"
    
    def test_capability_discovery(self):
        """Test capability discovery through registry."""
        from brain_researcher.tools.capabilities import list_capabilities, get_capability
        
        # List all capabilities
        capabilities = list_capabilities()
        assert len(capabilities) >= 4, "Should have at least 4 capabilities"
        assert "skull_strip" in capabilities
        assert "registration" in capabilities
        assert "segmentation" in capabilities
        assert "bias_correction" in capabilities
        
        # Get specific capability
        skull_strip_class = get_capability("skull_strip")
        assert skull_strip_class == SkullStripCapability
        
        # Test instantiation
        instance = skull_strip_class()
        assert hasattr(instance, "run")


@pytest.mark.parametrize("capability_name,capability_class", [
    ("skull_strip", SkullStripCapability),
    ("registration", RegistrationCapability),
    ("segmentation", SegmentationCapability),
    ("bias_correction", BiasCorrectionCapability),
])
def test_capability_backend_discovery(capability_name, capability_class):
    """Test that each capability can discover backends."""
    cap = capability_class()
    backends = cap.get_available_backends()
    
    # Should have at least one backend (Python fallback)
    assert len(backends) > 0, f"{capability_name} should have at least one backend"
    
    # Check backend info structure
    for name, info in backends.items():
        assert "type" in info
        assert "status" in info
        assert "version" in info


@pytest.mark.skipif(
    not Path("/cvmfs/neurodesk.ardc.edu.au").exists(),
    reason="CVMFS not available"
)
class TestPackageIntegration:
    """Test CVMFS-specific functionality (requires CVMFS)."""
    
    def test_package_container_discovery(self):
        """Test discovery of CVMFS containers."""
        resolver = PackageResolver()
        
        # Should find multiple tools
        tools = resolver.list_available_tools()
        assert len(tools) > 0, "Should find neuroimaging tools in CVMFS"
        
        # Check for common tools
        common_tools = ["fsl", "ants", "freesurfer", "mrtrix3"]
        found_tools = [t for t in common_tools if t in tools]
        assert len(found_tools) > 0, f"Should find at least one common tool, found: {list(tools.keys())}"
    
    def test_module_system_detection(self):
        """Test module system detection."""
        resolver = PackageResolver()
        
        # Check module system
        if resolver._module_system:
            assert resolver._module_system in ["lmod", "environment-modules"]
            
            # Try to find FSL module
            fsl_modules = resolver._find_cvmfs_modules("fsl")
            assert isinstance(fsl_modules, list)
    
    def test_apptainer_detection(self):
        """Test Apptainer/Singularity detection."""
        resolver = PackageResolver()
        
        # Should detect container runtime
        assert resolver._apptainer_available, "Should detect Apptainer or Singularity"