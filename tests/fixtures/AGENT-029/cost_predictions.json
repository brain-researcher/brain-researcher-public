{
  "neuroimaging_cost_models": [
    {
      "model_name": "fmriprep_preprocessing_cost",
      "description": "Cost prediction model for fMRIPrep preprocessing pipeline",
      "input_features": [
        {
          "name": "n_subjects",
          "type": "integer",
          "description": "Number of subjects to process",
          "range": [1, 1000]
        },
        {
          "name": "n_sessions_per_subject",
          "type": "integer", 
          "description": "Number of sessions per subject",
          "range": [1, 10],
          "default": 1
        },
        {
          "name": "n_runs_per_session",
          "type": "integer",
          "description": "Number of functional runs per session", 
          "range": [1, 20],
          "default": 4
        },
        {
          "name": "run_duration_minutes",
          "type": "float",
          "description": "Duration of each functional run in minutes",
          "range": [5.0, 60.0],
          "default": 10.0
        },
        {
          "name": "resolution_mm",
          "type": "float",
          "description": "Voxel resolution in mm",
          "range": [1.0, 5.0],
          "default": 2.0
        },
        {
          "name": "include_freesurfer",
          "type": "boolean",
          "description": "Whether to include FreeSurfer processing",
          "default": true
        },
        {
          "name": "output_spaces",
          "type": "array",
          "description": "List of output spaces for normalization",
          "options": ["T1w", "MNI152NLin2009cAsym", "MNI152NLin6Asym", "fsaverage"],
          "default": ["T1w", "MNI152NLin2009cAsym"]
        }
      ],
      "cost_components": {
        "base_cost_per_subject": 2.85,
        "session_multiplier": 0.95,
        "run_cost_factor": 0.15,
        "duration_cost_per_minute": 0.08,
        "resolution_cost_factor": {
          "1.0": 2.5,
          "1.5": 1.8,
          "2.0": 1.0,
          "2.5": 0.7,
          "3.0": 0.5
        },
        "freesurfer_addon": 1.20,
        "output_space_costs": {
          "T1w": 0.0,
          "MNI152NLin2009cAsym": 0.25,
          "MNI152NLin6Asym": 0.25,
          "fsaverage": 0.40
        }
      },
      "prediction_examples": [
        {
          "input": {
            "n_subjects": 20,
            "n_sessions_per_subject": 1,
            "n_runs_per_session": 4,
            "run_duration_minutes": 8.0,
            "resolution_mm": 2.0,
            "include_freesurfer": true,
            "output_spaces": ["T1w", "MNI152NLin2009cAsym"]
          },
          "predicted_cost": 95.50,
          "confidence_interval": [89.20, 101.80],
          "estimated_runtime_hours": 240,
          "cost_breakdown": {
            "base_preprocessing": 57.00,
            "freesurfer": 24.00,
            "output_spaces": 5.00,
            "compute_overhead": 9.50
          }
        },
        {
          "input": {
            "n_subjects": 100,
            "n_sessions_per_subject": 2,
            "n_runs_per_session": 6,
            "run_duration_minutes": 12.0,
            "resolution_mm": 1.5,
            "include_freesurfer": true,
            "output_spaces": ["T1w", "MNI152NLin2009cAsym", "fsaverage"]
          },
          "predicted_cost": 892.40,
          "confidence_interval": [825.60, 959.20],
          "estimated_runtime_hours": 2400,
          "cost_breakdown": {
            "base_preprocessing": 540.00,
            "freesurfer": 240.00,
            "high_resolution_addon": 80.40,
            "output_spaces": 32.00
          }
        }
      ]
    },
    {
      "model_name": "first_level_glm_cost",
      "description": "Cost prediction for first-level GLM analysis",
      "input_features": [
        {
          "name": "n_subjects",
          "type": "integer",
          "range": [1, 500]
        },
        {
          "name": "n_runs_per_subject", 
          "type": "integer",
          "range": [1, 20],
          "default": 4
        },
        {
          "name": "n_conditions",
          "type": "integer",
          "range": [2, 20],
          "default": 4
        },
        {
          "name": "smoothing_fwhm",
          "type": "float",
          "range": [0.0, 12.0],
          "default": 6.0
        },
        {
          "name": "motion_correction",
          "type": "string",
          "options": ["basic", "advanced", "ica_aroma"],
          "default": "basic"
        }
      ],
      "cost_components": {
        "base_cost_per_subject": 0.65,
        "run_multiplier": 1.05,
        "condition_cost": 0.08,
        "smoothing_cost_factor": 0.02,
        "motion_correction_costs": {
          "basic": 0.0,
          "advanced": 0.15,
          "ica_aroma": 0.25
