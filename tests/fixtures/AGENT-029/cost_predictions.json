      },
      "prediction_examples": [
        {
          "input": {
            "n_subjects": 50,
            "n_runs_per_subject": 4,
            "n_conditions": 6,
            "smoothing_fwhm": 6.0,
            "motion_correction": "ica_aroma"
          },
          "predicted_cost": 52.50,
          "confidence_interval": [48.80, 56.20],
          "estimated_runtime_hours": 18
        }
      ]
    },
    {
      "model_name": "group_analysis_cost",
      "description": "Cost prediction for group-level statistical analysis",
      "input_features": [
        {
          "name": "n_subjects",
          "type": "integer",
          "range": [10, 1000]
        },
        {
          "name": "analysis_type",
          "type": "string", 
          "options": ["one_sample_ttest", "two_sample_ttest", "paired_ttest", "anova", "regression"],
          "default": "one_sample_ttest"
        },
        {
          "name": "n_contrasts",
          "type": "integer",
          "range": [1, 50],
          "default": 4
        },
        {
          "name": "correction_method",
          "type": "string",
          "options": ["fwe", "fdr", "bonferroni", "none"],
          "default": "fwe"
        },
        {
          "name": "permutation_testing",
          "type": "boolean",
          "default": false
        },
        {
          "name": "n_permutations",
          "type": "integer",
          "range": [100, 10000],
          "default": 5000
        }
      ],
      "cost_components": {
        "base_analysis_cost": 8.50,
        "subject_cost_factor": 0.12,
        "analysis_type_multipliers": {
          "one_sample_ttest": 1.0,
          "two_sample_ttest": 1.3,
          "paired_ttest": 1.1,
          "anova": 1.8,
          "regression": 2.2
        },
        "contrast_cost": 1.25,
        "correction_overhead": {
          "fwe": 1.2,
          "fdr": 1.1,
          "bonferroni": 1.05,
          "none": 1.0
        },
        "permutation_cost_per_1000": 2.40
      }
    },
    {
      "model_name": "connectivity_analysis_cost",
      "description": "Cost prediction for functional connectivity analysis",
      "input_features": [
        {
          "name": "n_subjects",
          "type": "integer",
          "range": [10, 500]
        },
        {
          "name": "connectivity_type",
          "type": "string",
          "options": ["seed_based", "ica", "graph_theory", "dynamic_connectivity"],
          "default": "seed_based"
        },
        {
          "name": "n_seeds",
          "type": "integer",
          "range": [1, 100],
          "default": 6
        },
        {
          "name": "atlas_parcellation",
          "type": "string",
          "options": ["aal", "harvard_oxford", "schaefer_100", "schaefer_200", "schaefer_400"],
          "default": "schaefer_200"
        },
        {
          "name": "temporal_filtering",
          "type": "boolean",
          "default": true
        }
      ],
      "cost_components": {
        "base_connectivity_cost": 12.50,
        "subject_scaling": 0.18,
        "connectivity_type_multipliers": {
          "seed_based": 1.0,
          "ica": 2.5,
          "graph_theory": 3.2,
          "dynamic_connectivity": 4.8
        },
        "seed_cost": 0.85,
        "atlas_complexity": {
          "aal": 1.0,
          "harvard_oxford": 1.2,
          "schaefer_100": 1.1,
          "schaefer_200": 1.5,
          "schaefer_400": 2.2
        },
        "filtering_overhead": 0.15
      }
    }
  ],
