    },
    
    "aws_batch_expensive": {
      "backend_type": "aws_batch",
      "health_status": true,
      "capacity": {
        "total_cpu": 1000.0,
        "available_cpu": 800.0,
        "total_memory_gb": 4096.0,
        "available_memory_gb": 3200.0,
        "total_gpu": 64,
        "available_gpu": 48,
        "queue_depth": 12
      },
      "queue_time_estimate": 10,
