{
  "execution_plans": {
    "simple_neuroimaging_plan": {
      "plan_id": "simple_neuro_001",
      "description": "Simple neuroimaging pipeline for optimization testing",
      "steps": [
        {
          "step_id": "step_001",
          "step_number": 1,
          "description": "Anatomical preprocessing with FreeSurfer",
          "tool_name": "freesurfer_recon_all",
          "tool_args": {
            "subject_id": "sub-01",
            "input_dir": "/data/bids",
            "output_dir": "/data/derivatives/freesurfer"
          },
          "dependencies": [],
          "expected_output": "recon-all completed",
          "estimated_time_seconds": 28800,
          "resource_requirements": {
            "cpu": 8.0,
            "memory": 16.0,
            "storage": 50.0
          }
        },
        {
          "step_id": "step_002",
          "step_number": 2,
          "description": "Functional preprocessing with fMRIPrep",
          "tool_name": "fmriprep",
          "tool_args": {
            "bids_dir": "/data/bids",
            "output_dir": "/data/derivatives/fmriprep",
            "participant_label": "sub-01"
          },
          "dependencies": [],
          "expected_output": "fMRIPrep completed",
          "estimated_time_seconds": 14400,
          "resource_requirements": {
            "cpu": 4.0,
            "memory": 8.0,
            "storage": 30.0
          }
        },
        {
          "step_id": "step_003",
          "step_number": 3,
          "description": "GLM analysis",
          "tool_name": "fsl_feat",
          "tool_args": {
            "input_file": "/data/derivatives/fmriprep/sub-01_task-rest_bold.nii.gz",
            "design_file": "/data/design.fsf"
          },
          "dependencies": ["step_002"],
          "expected_output": "GLM results",
          "estimated_time_seconds": 3600,
          "resource_requirements": {
            "cpu": 2.0,
            "memory": 4.0,
            "storage": 10.0
          }
        },
        {
          "step_id": "step_004",
          "step_number": 4,
          "description": "Connectivity analysis",
          "tool_name": "connectivity_analysis",
          "tool_args": {
            "preprocessed_data": "/data/derivatives/fmriprep/sub-01_task-rest_bold.nii.gz",
            "atlas": "schaefer400"
          },
          "dependencies": ["step_002"],
          "expected_output": "Connectivity matrices",
          "estimated_time_seconds": 7200,
          "resource_requirements": {
            "cpu": 4.0,
            "memory": 8.0,
            "storage": 20.0
          }
        },
        {
          "step_id": "step_005",
          "step_number": 5,
          "description": "Surface-based analysis",
          "tool_name": "surface_analysis",
          "tool_args": {
            "freesurfer_dir": "/data/derivatives/freesurfer",
            "functional_data": "/data/derivatives/fmriprep/sub-01_task-rest_bold.nii.gz"
          },
          "dependencies": ["step_001", "step_002"],
          "expected_output": "Surface analysis results",
          "estimated_time_seconds": 5400,
          "resource_requirements": {
            "cpu": 2.0,
            "memory": 6.0,
            "storage": 15.0
          }
        },
        {
          "step_id": "step_006",
          "step_number": 6,
          "description": "Report generation",
          "tool_name": "generate_report",
          "tool_args": {
            "glm_results": "step_003",
            "connectivity_results": "step_004",
            "surface_results": "step_005"
          },
          "dependencies": ["step_003", "step_004", "step_005"],
          "expected_output": "Analysis report",
          "estimated_time_seconds": 1800,
          "resource_requirements": {
            "cpu": 1.0,
            "memory": 2.0,
            "storage": 5.0
          }
        }
      ]
    },
