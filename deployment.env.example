# ============================================================================
# Brain Researcher - Deployment Environment Configuration
# ============================================================================
# This file consolidates required environment variables for Docker/K8s deployment.
# Copy to deployment.env and configure for your environment.

# === Required: LLM API Keys (at least one) ===
# At minimum, provide ONE of these for the agent to function
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# === Required: Neo4j Database ===
# BR-KG knowledge graph requires Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-to-secure-password
NEO4J_DATABASE=neo4j

# === Required: Security ===
# JWT secret for authentication (min 32 chars, use same value everywhere)
JWT_SECRET_KEY=change-me-to-a-strong-random-string-min-32-chars
JWT_SECRET=change-me-to-a-strong-random-string-min-32-chars

# NextAuth secret for web UI (min 32 chars)
NEXTAUTH_SECRET=change-me-to-another-strong-random-string

# === Required: Redis ===
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# === Service URLs (internal Docker/K8s network) ===
NEUROKG_API_URL=http://neurokg:5000
AGENT_URL=http://agent:8000
ORCHESTRATOR_URL=http://orchestrator:3001

# === Web UI Configuration ===
# Recommended default: keep browser traffic same-origin through the Web UI proxy.
NEXT_PUBLIC_USE_API_PROXY=true
# Explicit internal service ownership for the Web UI server/proxy.
BR_AGENT_URL=http://agent:8000
BR_ORCHESTRATOR_URL=http://orchestrator:3001
BR_NEUROKG_URL=http://neurokg:5000
# Advanced / opt-out direct-public browser overrides (leave unset in proxy mode):
# NEXT_PUBLIC_AGENT_API=https://brain-researcher-api.example.com
# NEXT_PUBLIC_ORCHESTRATOR_URL=https://brain-researcher-api.example.com
# NEXT_PUBLIC_NEUROKG_API=https://brain-researcher-api.example.com/neurokg
# NEXT_PUBLIC_WS_URL=wss://brain-researcher-api.example.com/ws
NODE_ENV=production

# === Optional: PostgreSQL (if using for auth/metadata) ===
POSTGRES_USER=brain_researcher
POSTGRES_PASSWORD=change-me
POSTGRES_DB=brain_researcher
DATABASE_URL=postgresql://brain_researcher:change-me@postgres:5432/brain_researcher

# === Optional: Monitoring ===
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana
SLACK_API_URL=
PAGERDUTY_SERVICE_KEY=

# === Optional: Supabase (if using managed auth) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
BR_AUTH_PROVIDER=supabase
SUPABASE_OAUTH_PROVIDERS=google,github
NEXT_PUBLIC_SUPABASE_OAUTH_PROVIDERS=google,github

# === Performance Tuning ===
DEFAULT_LLM_MODEL=gemini-2.5-flash
WEB_CONCURRENCY=4
NEUROKG_MEMORY_LIMIT=3g
AGENT_MEMORY_LIMIT=4g

# === Environment/Mode ===
APP_ENV=production
BR_DEV_MODE=false
LOG_LEVEL=INFO

# === Tool Registry Rollout Defaults ===
BR_TOOL_REGISTRY_BACKEND=adapter
BR_TOOL_REGISTRY_MUTATION_MODE=compat
BR_TOOL_REGISTRY_FAIL_OPEN=true
BR_TOOL_EXECUTE_AUTO_REMAP=true
BR_TOOL_REGISTRY_LIGHT_MODE=false
