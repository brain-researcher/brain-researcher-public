    given-names: "Zijiao"
    email: "person@example.com"
    affiliation: "Stanford University"
  - name: "Brain Researcher contributors"
keywords:
  - "neuroimaging"
  - "fMRI"
  - "knowledge graph"
  - "large language model"
  - "research assistant"
  - "reproducibility"
  - "MCP"
  - "Model Context Protocol"
