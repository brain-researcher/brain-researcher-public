% ============================================================================
% STATISTIC HIGHLIGHT BOX
% ============================================================================

\newcommand{\statbox}[2]{%
    \begin{tcolorbox}[
        colback=primaryblue,
        colframe=primaryblue,
        coltext=white,
        arc=5pt,
        boxrule=0pt,
        width=0.3\textwidth,
        halign=center,
        valign=center,
        before skip=10pt,
        after skip=10pt,
    ]
    {\Huge\bfseries #1}\\[5pt]
    {\small #2}
    \end{tcolorbox}
}

% ============================================================================
% PUBLICATION-GRADE MANUSCRIPT PRIMITIVES
% ============================================================================

% Structured abstract helper for IMRAD-like manuscripts.
% #1 = Background, #2 = Methods, #3 = Results, #4 = Conclusions
\newcommand{\structuredabstract}[4]{%
    \begin{executivesummary}[Structured Abstract]
    \textbf{\textcolor{primaryblue}{Background.}} #1\par\medskip
    \textbf{\textcolor{primaryblue}{Methods.}} #2\par\medskip
    \textbf{\textcolor{primaryblue}{Results.}} #3\par\medskip
    \textbf{\textcolor{primaryblue}{Conclusions.}} #4
    \end{executivesummary}
}

% Compact keyword line for manuscript front matter.
\newcommand{\keywords}[1]{%
    \par\medskip
    \noindent\textbf{\textcolor{primaryblue}{Keywords:}} #1
    \par\medskip
}

% Optional manuscript metadata block for article type, version, and contact.
% #1 = Article type, #2 = Version/status, #3 = Correspondence/contact
\newcommand{\manuscriptmetadata}[3]{%
    \begin{definition}[Manuscript Metadata]
    \textbf{Article type.} #1\par\medskip
    \textbf{Version / status.} #2\par\medskip
    \textbf{Correspondence.} #3
    \end{definition}
}

% Methods card for reproducible method summaries.
% #1 = Study design, #2 = Inputs/data, #3 = Analysis, #4 = Validation
\newcommand{\methodcard}[4]{%
    \begin{methodology}[Methods Summary]
    \textbf{\textcolor{darkgreen}{Study design.}} #1\par\medskip
    \textbf{\textcolor{darkgreen}{Inputs.}} #2\par\medskip
    \textbf{\textcolor{darkgreen}{Analysis.}} #3\par\medskip
    \textbf{\textcolor{darkgreen}{Validation.}} #4
    \end{methodology}
}

% Discussion card for interpretation, implications, limitations, and next steps.
% #1 = Interpretation, #2 = Implication, #3 = Limitation, #4 = Next step
\newcommand{\discussioncard}[4]{%
    \begin{recommendations}[Discussion Summary]
    \textbf{\textcolor{recommendpurple}{Interpretation.}} #1\par\medskip
    \textbf{\textcolor{recommendpurple}{Implication.}} #2\par\medskip
    \textbf{\textcolor{cautionorange}{Limitation.}} #3\par\medskip
    \textbf{\textcolor{recommendpurple}{Next step.}} #4
    \end{recommendations}
}

% Research-question card for the end of an introduction.
% #1 = Question, #2 = Rationale/gap, #3 = Decision criterion or test
\newcommand{\researchquestion}[3]{%
    \begin{hypothesis}[Research Question]
    \textbf{\textcolor{primaryblue}{Question.}} #1\par\medskip
    \textbf{\textcolor{primaryblue}{Rationale.}} #2\par\medskip
    \textbf{\textcolor{primaryblue}{Decision criterion.}} #3
    \end{hypothesis}
}

% Contribution summary for manuscript introductions.
% #1 = Scientific contribution, #2 = Methodological contribution, #3 = Reproducibility contribution
\newcommand{\contributionbox}[3]{%
    \begin{keyfindings}[Contributions]
    \textbf{\textcolor{primaryblue}{Scientific.}} #1\par\medskip
    \textbf{\textcolor{primaryblue}{Methodological.}} #2\par\medskip
    \textbf{\textcolor{primaryblue}{Reproducibility.}} #3
    \end{keyfindings}
}

% Data/provenance card for methods sections.
% #1 = Source/dataset, #2 = Version/access, #3 = Inclusion/exclusion, #4 = Known limitations
\newcommand{\dataprovenancecard}[4]{%
    \begin{reproducibility}[Data Provenance]
    \textbf{Source / dataset.} #1\par\medskip
    \textbf{Version / access.} #2\par\medskip
    \textbf{Inclusion / exclusion.} #3\par\medskip
    \textbf{Known limitations.} #4
    \end{reproducibility}
}

% Model/procedure provenance card for ML, encoding, and computational reports.
% #1 = Model/procedure, #2 = Inputs, #3 = Outputs, #4 = Failure modes/boundaries
\newcommand{\modelprovenancecard}[4]{%
    \begin{reproducibility}[Model Provenance]
    \textbf{Model / procedure.} #1\par\medskip
    \textbf{Inputs.} #2\par\medskip
    \textbf{Outputs.} #3\par\medskip
    \textbf{Failure modes / boundaries.} #4
    \end{reproducibility}
}

% Statistical analysis card for inference details.
% #1 = Primary estimand, #2 = Null/exchangeability, #3 = Multiplicity, #4 = Sensitivity checks
\newcommand{\statisticalanalysiscard}[4]{%
    \begin{methodology}[Statistical Analysis]
    \textbf{\textcolor{darkgreen}{Primary estimand.}} #1\par\medskip
    \textbf{\textcolor{darkgreen}{Null model / exchangeability.}} #2\par\medskip
    \textbf{\textcolor{darkgreen}{Multiplicity control.}} #3\par\medskip
    \textbf{\textcolor{darkgreen}{Sensitivity checks.}} #4
    \end{methodology}
}

% Robustness and falsification card for results/discussion.
% #1 = Internal validation, #2 = Sensitivity checks, #3 = Negative/falsification tests, #4 = Residual risk
\newcommand{\robustnesscard}[4]{%
    \begin{evidencebox}[Robustness And Falsification]
    \textbf{\textcolor{darkgreen}{Internal validation.}} #1\par\medskip
    \textbf{\textcolor{darkgreen}{Sensitivity checks.}} #2\par\medskip
    \textbf{\textcolor{criticalred}{Negative / falsification tests.}} #3\par\medskip
    \textbf{\textcolor{cautionorange}{Residual risk.}} #4
    \end{evidencebox}
}

% Limitations card for explicit claim boundaries.
% #1 = Evidence boundary, #2 = Confounds, #3 = Generalizability, #4 = Missing validation
\newcommand{\limitationscard}[4]{%
    \begin{claimboundary}[Limitations And Claim Boundary]
    \textbf{Evidence boundary.} #1\par\medskip
    \textbf{Potential confounds.} #2\par\medskip
    \textbf{Generalizability.} #3\par\medskip
    \textbf{Missing validation.} #4
    \end{claimboundary}
}

% Reproducibility manifest for paths, scripts, environment, and outputs.
% #1 = Repository/code, #2 = Scripts/commands, #3 = Environment, #4 = Data/artifacts, #5 = Outputs
\newcommand{\reproducibilitymanifest}[5]{%
    \begin{reproducibility}[Reproducibility Manifest]
    \textbf{Repository / code.} #1\par\medskip
    \textbf{Scripts / commands.} #2\par\medskip
    \textbf{Environment.} #3\par\medskip
    \textbf{Data / artifacts.} #4\par\medskip
    \textbf{Outputs.} #5
    \end{reproducibility}
}

% Compact artifact/path entry for execution packs.
% #1 = Purpose, #2 = Path/identifier, #3 = Status or checksum
\newcommand{\artifactentry}[3]{%
    \par\noindent
    \textbf{\textcolor{primaryblue}{#1.}} \path|#2|\par
    {\small\textit{Status: #3}}\par\medskip
}

% Claim matrix row helper for manuscript-style evidence summaries.
% #1 = Claim, #2 = Status/level, #3 = Evidence, #4 = Boundary/next test
\newcommand{\claimmatrixitem}[4]{%
    \par\noindent
    \textbf{\textcolor{primaryblue}{Claim.}} #1\par
    \textbf{Status.} #2\par
    \textbf{Evidence.} #3\par
    \textbf{Boundary / next test.} #4
    \par\medskip
}

% Scientific review/adjudication box.
\newtcolorbox{reviewbox}[1][Scientific Review]{
    enhanced,
    breakable,
    colback=white,
    colframe=primaryblue,
    fonttitle=\bfseries\color{white},
    title=#1,
    coltitle=white,
    colbacktitle=primaryblue,
    boxrule=0.9pt,
    arc=3pt,
    borderline west={3pt}{0pt}{secondaryblue},
    left=10pt,
    right=10pt,
    top=8pt,
    bottom=8pt,
    before skip=12pt,
    after skip=12pt,
}

% #1 = finding label, #2 = severity/status, #3 = review text
\newcommand{\reviewfinding}[3]{%
    \par\noindent
    \textbf{\textcolor{primaryblue}{#1.}}
    \textbf{Severity / status:} #2. #3
    \par\medskip
}

% #1 = verdict label, #2 = rationale
\newcommand{\reviewverdict}[2]{%
    \par\medskip
    \noindent\textbf{\textcolor{primaryblue}{Review verdict:}} #1\par
    \noindent #2
    \par\medskip
}

% Reviewer-response helper for revised reports and review appendices.
% #1 = Reviewer comment, #2 = Response, #3 = Manuscript/template change
\newcommand{\reviewresponse}[3]{%
    \begin{reviewbox}[Reviewer Response]
    \textbf{\textcolor{primaryblue}{Comment.}} #1\par\medskip
    \textbf{\textcolor{darkgreen}{Response.}} #2\par\medskip
    \textbf{\textcolor{recommendpurple}{Change made.}} #3
    \end{reviewbox}
}

\newenvironment{reviewchecklist}{%
    \begin{itemize}[leftmargin=1.5em]
}{%
    \end{itemize}
}

\newcommand{\reviewpass}[1]{\item \textbf{\textcolor{darkgreen}{PASS}} -- #1}
\newcommand{\reviewwarn}[1]{\item \textbf{\textcolor{cautionorange}{WARN}} -- #1}
\newcommand{\reviewblock}[1]{\item \textbf{\textcolor{criticalred}{BLOCK}} -- #1}

% Reporting/checklist table for CONSORT/STROBE/PRISMA-like requirements.
\newenvironment{reportingchecklist}[1][Reporting Checklist]{%
    \begin{reproducibility}[#1]
    \begin{itemize}[leftmargin=1.5em]
}{%
    \end{itemize}
    \end{reproducibility}
}

% #1 = Checklist item, #2 = Location/status
\newcommand{\checklistitem}[2]{%
    \item \textbf{\textcolor{primaryblue}{#1.}} #2%
}

% Publication statement helpers for manuscript end matter.
\newcommand{\publicationstatement}[2]{%
    \begin{definition}[#1]
    #2
    \end{definition}
}

\newcommand{\ethicsstatement}[1]{\publicationstatement{Ethics Statement}{#1}}
\newcommand{\dataavailability}[1]{\publicationstatement{Data Availability}{#1}}
\newcommand{\codeavailability}[1]{\publicationstatement{Code Availability}{#1}}
\newcommand{\authorcontributions}[1]{\publicationstatement{Author Contributions}{#1}}
\newcommand{\fundingstatement}[1]{\publicationstatement{Funding}{#1}}
\newcommand{\conflictsofinterest}[1]{\publicationstatement{Competing Interests}{#1}}
\newcommand{\acknowledgements}[1]{\publicationstatement{Acknowledgements}{#1}}

% Lightweight reference helpers for reports that do not use a .bib file.
\newenvironment{publicationreferences}{%
    \begin{small}
}{%
    \end{small}
}

\newcommand{\doiurl}[1]{\href{https://doi.org/#1}{doi:\nolinkurl{#1}}}

% #1 = reference key/number, #2 = citation text, #3 = DOI/URL or empty
\newcommand{\referenceentry}[3]{%
    \par\noindent\hangindent=1.5em\hangafter=1
    \textbf{#1.} #2%
    \if\relax\detokenize{#3}\relax\else\ \url{#3}\fi
    \par\medskip
}

\newcommand{\referencesnote}[1]{%
    \par\smallskip
    {\small\itshape Note: #1}
    \par\medskip
}

% BibTeX helper for reports that provide a .bib file next to the .tex file.
% #1 = bibliography style, #2 = bibliography file stem/path
\newcommand{\reportbibliography}[2]{%
    \bibliographystyle{#1}
    \bibliography{#2}
}

% ============================================================================
% TABLE STYLING
% ============================================================================

% Alternating row colors command
\newcommand{\tablerowcolor}{\rowcolor{tablealt}}

% Table header styling
\newcommand{\tableheader}[1]{\textbf{\color{white}#1}}
\newcommand{\tableheaderrow}{\rowcolor{primaryblue}}

% Professional table environment
\newenvironment{sciencetable}[2][htbp]{%
    \begin{table}[#1]
    \centering
    \caption{#2}
    \small
}{%
    \end{table}
}

% ============================================================================
% FIGURE STYLING
% ============================================================================

% Keep figures and tables numbered globally instead of chapter-prefixed
% (e.g. Figure 1 instead of Figure 3.1) because generated MCP reports often
% already use manuscript-style figure ordering.
\counterwithout{figure}{chapter}
\counterwithout{table}{chapter}

% Caption formatting
\captionsetup{
    font=small,
    labelfont={bf,color=primaryblue},
    textfont={color=darkgray},
    justification=centering,
    margin=20pt,
}

% Figure with source attribution
\newcommand{\figuresource}[1]{%
    \par\vspace{-8pt}
    {\small\textit{Source: #1}}
}

% Figure note (use outside table environments, after \end{tabular})
\newcommand{\figurenote}[1]{%
    \par\vspace{-8pt}
    {\small\textit{Note: #1}}
}

% Graphical abstract / hero figure helper.
% #1 = image path, #2 = caption, #3 = note/source text
\newcommand{\graphicalabstract}[3]{%
    \begin{figure}[htbp]
    \centering
    \IfFileExists{#1}{%
        \includegraphics[width=0.95\linewidth]{#1}%
    }{%
        \fbox{\parbox{0.9\linewidth}{\centering Graphical abstract unavailable: \path|#1|}}%
    }%
    \caption{#2}
    \if\relax\detokenize{#3}\relax\else
        \figurenote{#3}
    \fi
    \end{figure}
}

% Report figure helper with separate short and full captions.
% #1 = image path, #2 = short list-of-figures caption, #3 = full caption, #4 = note/source text
\newcommand{\reportfigure}[4]{%
    \begin{figure}[htbp]
    \centering
    \IfFileExists{#1}{%
        \includegraphics[width=0.95\linewidth]{#1}%
    }{%
        \fbox{\parbox{0.9\linewidth}{\centering Figure unavailable: \path|#1|}}%
    }%
    \caption[#2]{#3}
    \if\relax\detokenize{#4}\relax\else
        \figurenote{#4}
    \fi
    \end{figure}
}

% Supplementary numbering helpers. Use at the start of supplementary sections.
\newcommand{\beginsupplement}{%
    \setcounter{figure}{0}
    \setcounter{table}{0}
    \renewcommand{\thefigure}{S\arabic{figure}}
    \renewcommand{\thetable}{S\arabic{table}}
}

% Compact claim-card helper.
% #1 = title, #2 = claim text, #3 = evidence text, #4 = boundary/next-test text
\newcommand{\claimcard}[4]{%
    \begin{tcolorbox}[
        enhanced,
        colback=white,
        colframe=primaryblue,
        title=#1,
        coltitle=white,
        colbacktitle=primaryblue,
        fonttitle=\bfseries,
        boxrule=0.9pt,
        arc=3pt,
        left=10pt,
        right=10pt,
        top=8pt,
        bottom=8pt,
        before skip=12pt,
        after skip=12pt,
    ]
    \textbf{\textcolor{primaryblue}{Claim.}} #2\par\medskip
    \textbf{\textcolor{darkgreen}{Evidence.}} #3\par\medskip
    \textbf{\textcolor{cautionorange}{Boundary / Next test.}} #4
    \end{tcolorbox}
}

% Table note (use INSIDE tabular, before \bottomrule)
% #1 = number of columns in the tabular
% #2 = note text
% Usage: \tablenote{4}{DMN-A labels are unreliable...}
\newcommand{\tablenote}[2]{%
    \multicolumn{#1}{@{}p{0.95\linewidth}@{}}{%
        {\small\itshape Note: #2}%
    } \\
}

