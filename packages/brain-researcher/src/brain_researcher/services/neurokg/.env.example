# Railway Environment Variables Template
# Copy this to .env for local development

# API Configuration
API_URL=http://localhost:5000
PORT=5000

# Database Configuration
# For deployment, use JSON database included in repo
NEUROKG_GLMFITLINS_DB_PATH=neurokg_glmfitlins_export.json

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Optional: Analytics or monitoring
# SENTRY_DSN=your_sentry_dsn_here

# Optional: Custom domain configuration
# ALLOWED_HOSTS=brain-researcher.com,neurokg.brain-researcher.com
