{
  "$defs": {
    "ArtifactKindV1": {
      "enum": [
        "file",
        "json",
        "blob",
        "bundle",
        "log",
        "trace"
      ],
      "title": "ArtifactKindV1",
      "type": "string"
    },
    "ArtifactV1": {
      "properties": {
        "artifact_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional stable artifact identifier",
          "title": "Artifact Id"
        },
        "bytes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Size in bytes when known",
          "title": "Bytes"
        },
        "created_at": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Unix timestamp (seconds) when recorded",
          "title": "Created At"
        },
        "ids": {
          "$ref": "#/$defs/IdsV1"
        },
        "job_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Owning job/analysis identifier",
          "title": "Job Id"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKindV1",
          "description": "High-level artifact kind"
        },
        "media_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "IANA media type (e.g. application/json, text/plain)",
          "title": "Media Type"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "policy": {
          "$ref": "#/$defs/PolicyRefV1"
        },
        "schema_version": {
          "const": "artifact-v1",
          "default": "artifact-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Checksum in the form sha256:<hex> when available",
          "title": "Sha256"
        },
        "tags": {
          "description": "Semantic tags/roles",
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "uri": {
          "description": "Relative path within the run directory, or an abstract URI",
          "title": "Uri",
          "type": "string"
        },
        "versions": {
          "$ref": "#/$defs/VersionRefV1"
        }
      },
      "required": [
        "kind",
        "uri"
      ],
      "title": "ArtifactV1",
      "type": "object"
    },
    "IdsV1": {
      "description": "Stable identifiers for correlating objects/events across services.",
      "properties": {
        "analysis_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Analysis identifier if applicable",
          "title": "Analysis Id"
        },
        "job_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Job identifier",
          "title": "Job Id"
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Inbound API/UI request identifier",
          "title": "Request Id"
        },
        "run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Run identifier",
          "title": "Run Id"
        },
        "schema_version": {
          "const": "ids-v1",
          "default": "ids-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "session_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Conversation/session/thread id",
          "title": "Session Id"
        },
        "trace_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Distributed trace id",
          "title": "Trace Id"
        },
        "user_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "End-user id",
          "title": "User Id"
        },
        "workspace_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Workspace/project id",
          "title": "Workspace Id"
        }
      },
      "title": "IdsV1",
      "type": "object"
    },
    "PolicyRefV1": {
      "description": "Reference to the policy that governed a run/event.",
      "properties": {
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Human-readable notes",
          "title": "Notes"
        },
        "policy_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Checksum in the form sha256:<hex> when available",
          "title": "Policy Hash"
        },
        "policy_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Policy identifier",
          "title": "Policy Id"
        },
        "policy_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Where the policy came from (file/env/url)",
          "title": "Policy Source"
        },
        "schema_version": {
          "const": "policy-ref-v1",
          "default": "policy-ref-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "thresholds": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional thresholds used by the policy",
          "title": "Thresholds"
        }
      },
      "title": "PolicyRefV1",
      "type": "object"
    },
    "ProvenanceKindV1": {
      "enum": [
        "tool",
        "step",
        "workflow",
        "stage",
        "pipeline"
      ],
      "title": "ProvenanceKindV1",
      "type": "string"
    },
    "ProvenanceRuntimeV1": {
      "properties": {
        "container": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Container"
        },
        "git": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git"
        },
        "host": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Host"
        },
        "sandbox": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sandbox"
        }
      },
      "title": "ProvenanceRuntimeV1",
      "type": "object"
    },
    "ProvenanceStatusV1": {
      "enum": [
        "scheduled",
        "running",
        "succeeded",
        "failed",
        "partial",
        "timeout",
        "cancelled"
      ],
      "title": "ProvenanceStatusV1",
      "type": "string"
    },
    "ProvenanceTimestampsV1": {
      "properties": {
        "duration_sec": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Duration Sec"
        },
        "finished_at": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finished At"
        },
        "started_at": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Started At"
        }
      },
      "title": "ProvenanceTimestampsV1",
      "type": "object"
    },
    "VersionRefV1": {
      "description": "Best-effort versions for reproducibility/auditing.",
      "properties": {
        "brain_researcher_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Installed brain_researcher package version",
          "title": "Brain Researcher Version"
        },
        "contracts_version": {
          "default": "contracts-v1",
          "description": "Version identifier for this contract set",
          "title": "Contracts Version",
          "type": "string"
        },
        "git_commit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Git commit SHA if known",
          "title": "Git Commit"
        },
        "image_digests": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Container/image digests",
          "title": "Image Digests",
          "type": "object"
        },
        "schema_version": {
          "const": "version-ref-v1",
          "default": "version-ref-v1",
          "title": "Schema Version",
          "type": "string"
        },
        "tool_versions": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Tool/library versions",
          "title": "Tool Versions",
          "type": "object"
        }
      },
      "title": "VersionRefV1",
      "type": "object"
    }
  },
  "properties": {
    "command": {
      "items": {
        "type": "string"
      },
      "title": "Command",
      "type": "array"
    },
    "error_message": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error Message"
    },
    "exit_code": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Exit Code"
    },
    "ids": {
      "$ref": "#/$defs/IdsV1"
    },
    "inputs": {
      "items": {
        "$ref": "#/$defs/ArtifactV1"
      },
      "title": "Inputs",
      "type": "array"
    },
    "kind": {
      "$ref": "#/$defs/ProvenanceKindV1",
      "default": "tool"
    },
    "logs": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Logs"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "outputs": {
      "items": {
        "$ref": "#/$defs/ArtifactV1"
      },
      "title": "Outputs",
      "type": "array"
    },
    "parameters": {
      "additionalProperties": true,
      "title": "Parameters",
      "type": "object"
    },
    "policy": {
      "$ref": "#/$defs/PolicyRefV1"
    },
    "resources": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Resources"
    },
    "run_id": {
      "description": "Execution run identifier (tool/run recorder id)",
      "title": "Run Id",
      "type": "string"
    },
    "runtime": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProvenanceRuntimeV1"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "schema_version": {
      "const": "provenance-v1",
      "default": "provenance-v1",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/ProvenanceStatusV1",
      "default": "succeeded"
    },
    "timestamps": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProvenanceTimestampsV1"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "versions": {
      "$ref": "#/$defs/VersionRefV1"
    }
  },
  "required": [
    "run_id"
  ],
  "title": "ProvenanceV1",
  "type": "object"
}
