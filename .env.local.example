# Planner/agent orchestration defaults for local development
# Copy this file to .env.local and tweak as needed.

# Advisor vs autorun: advisor = plan only, autorun = plan + execute
BR_PLANNER_MODE=autorun

# Default planner source when requests omit `mode`
BR_PLANNER_SOURCE=catalog

# Restrict tools that planner and executor may choose; use comma-separated IDs
AGENT_TOOL_ALLOWLIST=*

# Enable sandbox and cap DAG concurrency for plan execution workers
BR_SANDBOX_ENABLED=true
BR_DAG_MAX_CONCURRENCY=2

# Enable result caching (P2.5 feature): cache completed job results based on inputs
BR_CACHE_ENABLED=true

# Cache fingerprinting mode: fast (default), secure, or paranoid
BR_CACHE_MODE=fast

# =============================================================================
# Studio notebook execution (Jupyter kernel)
# Run scripts/setup/setup_local_runtime.sh to create the env and start Jupyter.
# The script will print the exact values to paste here.
# =============================================================================

# Local Jupyter server URL (no trailing slash)
BR_STUDIO_JUPYTER_BASE_URL=http://127.0.0.1:8888

# Jupyter server token (printed by setup_local_runtime.sh)
BR_STUDIO_JUPYTER_TOKEN=<set by setup_local_runtime.sh>

# Jupyter kernel name registered by setup_local_runtime.sh
BR_STUDIO_JUPYTER_KERNEL_NAME=brain_researcher

# Conda environment used by NeurodeskCompiler and notebook execution
BR_CONDA_ENV=brain_researcher

# Neurodesk dispatch mode (handoff = compile + hand off script to user/Neurodesk)
BR_NEURODESK_MODE=handoff
BR_NEURODESK_CONFIRM=true
