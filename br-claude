#!/usr/bin/env bash
# Brain Researcher CLI launcher
# Usage: br-claude [claude args...]

BR_MCP_URL="${BR_MCP_URL:-https://brain-researcher.com/mcp}"
BR_MCP_AUTH_TOKEN="${BR_MCP_AUTH_TOKEN:-${BR_MCP_TOKEN:-}}"

MCP_JSON=""
if [ -n "$BR_MCP_AUTH_TOKEN" ]; then
  MCP_JSON="{\"mcpServers\":{\"brain-researcher\":{\"type\":\"http\",\"url\":\"${BR_MCP_URL}\",\"headers\":{\"Authorization\":\"Bearer ${BR_MCP_AUTH_TOKEN}\"}}}}"
fi

exec bun ${HOME}/projects/claude-code/dist/cli.mjs \
  ${MCP_JSON:+--mcp-config "$MCP_JSON"} \
  "$@"
