# Brain Researcher Environment Configuration
# Copy this file to .env and configure with your values

# === API Keys ===

# Google API Key
GEMINI_API_KEY=your_gemeni_api_key_here

# OpenAI API key for LLM operations
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API key (optional, for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek API key (optional, for alternative models)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# NCBI Entrez (PubMed). Email is required by NCBI policies.
NCBI_ENTREZ_EMAIL=your_email@example.com
# Optional API key increases rate limits.
NCBI_ENTREZ_API_KEY=your_ncbi_entrez_api_key_here

# AWS (optional; used for AWS Batch backend)
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_SESSION_TOKEN=your_aws_session_token_here
AWS_DEFAULT_REGION=us-east-1

# Google / Gemini API keys (optional; only used when not using local Gemini CLI)
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# === Database Configuration ===
# PostgreSQL settings (optional, for production)
POSTGRES_PASSWORD=brain_researcher_secure_password
POSTGRES_USER=brain_researcher
POSTGRES_DB=brain_researcher

# Redis password (optional but recommended)
REDIS_PASSWORD=your_redis_password_here

# === Neo4j Configuration ===
# Neo4j connection settings (required for BR-KG knowledge graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j
# Preload frequently accessed nodes into memory cache on startup
NEO4J_PRELOAD_CACHE=true
# Preferred fulltext index for KG search (set to kgNodeFulltext after schema update)
NEO4J_FULLTEXT_NODE_INDEX=kgNodeFulltext

# === Security ===
# Unified JWT secret for all services (orchestrator, gateway, agent, etc.)
JWT_SECRET_KEY=change-me-to-a-strong-random-string-and-use-the-same-value-everywhere
# Legacy variable (still read in a few places; keep in sync with JWT_SECRET_KEY if used)
JWT_SECRET=your_very_secure_jwt_secret_key_here_at_least_32_characters

# MCP token verification (shared by orchestrator + mcp)
BR_MCP_AUTH_MODE=token_or_jwt
BR_MCP_TOKEN_PEPPER=replace_with_64_hex_chars
BR_MCP_TOKEN_PEPPER_VERSION=v1
BR_MCP_TOKEN_REDIS_PREFIX=mcp_token

# === Claude Code (CC) Integration ===
# Used by docker-compose.cc-stack.yml (litellm + br-mcp services).
#
# Simple static token CC uses to authenticate with the MCP server.
# Generate with: openssl rand -hex 32
# Set BR_MCP_AUTH_MODE=token to use this instead of the Redis-based token.
BR_MCP_AUTH_TOKEN=replace_with_openssl_rand_hex_32
#
# CC connects to:
#   BR_MCP_URL=http://localhost:7000/mcp      (br-mcp container)
#   ANTHROPIC_BASE_URL=http://localhost:4000  (litellm proxy → Gemini)
#   ANTHROPIC_API_KEY=sk-br-local            (dummy key; litellm validates it)
#
# Start the full CC stack:
#   docker compose -f docker-compose.yml -f docker-compose.cc-stack.yml up -d
#
# Then launch CC:
#   ANTHROPIC_BASE_URL=http://localhost:4000 \
#   ANTHROPIC_API_KEY=sk-br-local \
#   BR_MCP_URL=http://localhost:7000/mcp \
#   claude

# API Gateway configuration
GATEWAY_SECRET_KEY=your_gateway_secret_key_here

# === External Services ===
# Supabase configuration (optional, for user management)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_OAUTH_PROVIDERS=google,github

# Public Supabase settings for the Web UI (used in client bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_OAUTH_PROVIDERS=google,github

# Auth provider selection for UI (supabase | nextauth | both)
NEXT_PUBLIC_AUTH_MODE=supabase
BR_AUTH_PROVIDER=supabase

# NextAuth secrets/providers (optional; used when auth mode is nextauth or both)
NEXTAUTH_SECRET=change-me-to-a-strong-random-string
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
AZURE_AD_CLIENT_ID=your_azure_ad_client_id
AZURE_AD_CLIENT_SECRET=your_azure_ad_client_secret
AZURE_AD_TENANT_ID=common

# Dev-only credentials login (optional)
ENABLE_DEV_CREDENTIALS=0
DEV_CREDENTIALS_EMAIL=dev@local
DEV_CREDENTIALS_PASSWORD=devpass123

# === Monitoring ===
# Grafana admin password
GRAFANA_PASSWORD=admin_password_here

# Slack webhook for notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Slack session bridge (optional; used by /api/sessions Slack integration)
# Use the bot token and signing secret from your Slack app installation.
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Public HTTPS base URL that Slack can reach (deployment URL or tunnel).
# Used by the CLI manifest helper and recommended for local Slack E2E setup.
BR_PUBLIC_BASE_URL=https://your-public-orchestrator.example.com

# Telemetry service (Usage/Events/Grafana)
TELEMETRY_INTERNAL_URL=http://localhost:8003
TELEMETRY_SERVICE_TOKEN=dev-telemetry-token

# Web UI telemetry proxy target (used by Next.js /api/telemetry/**)
NEXT_PUBLIC_TELEMETRY_UPSTREAM=http://localhost:8003

# Feedback widget visibility (set to false to hide in beta)
NEXT_PUBLIC_ENABLE_FEEDBACK_WIDGET=true

# === Environment Settings ===
# Application environment
NODE_ENV=production
FLASK_ENV=production

# Dev-mode toggle for cookie attributes (refresh token):
# BR_DEV_MODE=true  → secure=False, SameSite=Lax (HTTP localhost)
# BR_DEV_MODE=false → secure=True,  SameSite=Strict (production HTTPS)
BR_DEV_MODE=false

# Debug settings
BR_DEBUG=false
LOG_LEVEL=INFO

# === Performance ===
# Worker processes
WEB_CONCURRENCY=4
GUNICORN_WORKERS=4

# Memory limits
BR_KG_MEMORY_LIMIT=3g
AGENT_MEMORY_LIMIT=4g

# === Data Paths ===
# BR-KG database path
BR_KG_DB_PATH=/app/data/br-kg/db/br-kg_full.db

# Data directory
DATA_DIR=/app/data

# === Networking ===
# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Public/API URLs (UI and server-side fetches)
NEXT_PUBLIC_API_URL=http://localhost:8080          # Gateway (single public entrypoint)
INTERNAL_API_URL=http://localhost:8080             # Server-side fetch target (SSR hits gateway)
PUBLIC_API_URL=http://localhost:8080
PUBLIC_ORCHESTRATOR_URL=http://localhost:3001
PUBLIC_AGENT_URL=http://localhost:8000
PUBLIC_BR_KG_URL=http://localhost:5000
PUBLIC_WS_URL=/ws

# Direct service URLs (used by the UI if proxying is disabled)
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:3001
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
NEXT_PUBLIC_BR_KG_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=/ws
NEXT_PUBLIC_USE_API_PROXY=true

# Domain configuration
DOMAIN=yourdomain.com
SSL_EMAIL=admin@yourdomain.com

# === Feature Flags ===
# Enable/disable features
ENABLE_NICLIP=true
ENABLE_MONITORING=true
ENABLE_BACKUP=true

# Demo mode for orchestrator service
# - production: Legacy DEMO_SCENARIOS endpoints are blocked (default, recommended)
# - development: Legacy fake demo endpoints are accessible for UI prototyping
# NOTE: Use /api/demo/real-* endpoints for production demo results
BR_DEMO_MODE=production

# === LLM Configuration ===
# Default LLM model selection for the agent. Examples:
#   DEFAULT_LLM_MODEL=gpt-4o
#   DEFAULT_LLM_MODEL=claude-3-5-sonnet
#   DEFAULT_LLM_MODEL=deepseek-chat
#   DEFAULT_LLM_MODEL=gemini-3-flash-preview
DEFAULT_LLM_MODEL=gemini-3-flash-preview
# Default coding/agentic model when coding mode is enabled.
DEFAULT_CODING_MODEL=gemini-3-flash-preview

# Use local Gemini CLI via OAuth (free daily credits). When true and
# DEFAULT_LLM_MODEL contains 'gemini', the agent /chat endpoint will attempt to
# call the local `gemini` CLI first, falling back to the configured API model
# on failure.
USE_GEMINI_CLI=true
# Gemini credential preference for Gemini models:
#   local_oauth_first (default legacy behavior when USE_GEMINI_CLI=true)
#   byok_first        (prefer GEMINI_API_KEY / configured BYOK Gemini over CLI OAuth)
#   local_oauth_only  (disable Gemini BYOK fallback)
#   byok_only         (disable local Gemini CLI fallback)
BR_GEMINI_CREDENTIAL_PREFERENCE=local_oauth_first

# === LLM Budget Management (Track 1) ===
# Enable budget enforcement for LLM API usage
ENABLE_LLM_BUDGET_TRACKING=true

# Default budget limits (when creating new budgets)
# Token limits
DEFAULT_DAILY_TOKEN_LIMIT=1000000
DEFAULT_MONTHLY_TOKEN_LIMIT=10000000

# USD limits
DEFAULT_DAILY_USD_LIMIT=10.00
DEFAULT_MONTHLY_USD_LIMIT=100.00

# Budget enforcement type: hard_limit, soft_limit, or advisory
DEFAULT_BUDGET_TYPE=hard_limit

# Alert thresholds (percentages, comma-separated)
DEFAULT_BUDGET_ALERT_THRESHOLDS=50,80,95

# === Managed LLM Credentials (Track 1) ===
# Platform-managed credentials that can be shared across budgets
# Format: MANAGED_{PROVIDER}_API_KEY_{INDEX}

# Managed Gemini credentials
# MANAGED_GEMINI_API_KEY_1=your_managed_gemini_key_here
# MANAGED_GEMINI_API_KEY_2=your_second_managed_gemini_key_here

# Managed OpenAI credentials
# MANAGED_OPENAI_API_KEY_1=your_managed_openai_key_here

# Budget IDs authorized for each managed credential (comma-separated)
# MANAGED_GEMINI_BUDGET_IDS_1=proj_123,proj_456,workspace_789
# MANAGED_GEMINI_BUDGET_IDS_2=proj_abc,proj_xyz
# MANAGED_OPENAI_BUDGET_IDS_1=enterprise_budget_1

# Maximum concurrent allocations per managed credential
MANAGED_CREDENTIAL_MAX_CONCURRENT=10

# Rate limits for managed credentials (optional)
# MANAGED_GEMINI_RATE_LIMIT_RPM=100
# MANAGED_GEMINI_RATE_LIMIT_RPD=10000

# === Backup Configuration ===
# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Backup schedule (cron format)
BACKUP_SCHEDULE="0 2 * * *"

# === Development Settings ===
# Only used in development
DEV_MODE=false
MOCK_EXTERNAL_APIS=false

# === Planner ===
# Default planner source. Use "catalog" (hybrid) to include curated+generated tools
# (container, python, LLM/coding) with legacy fallback; set to "legacy" to disable
# catalog-based planning.
BR_PLANNER_SOURCE=catalog

# Cloudflare (infrastructure/cloudflare/*.py) — supply your own values
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_DOMAIN=brain-researcher.com
CLOUDFLARE_SERVER_IP=your_origin_server_ip
